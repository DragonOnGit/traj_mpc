<launch>
  <!-- Static Transform Parameters: map to camera_init -->
  <param name="map_to_camera_init_x" value="0.0" />
  <param name="map_to_camera_init_y" value="0.0" />
  <param name="map_to_camera_init_z" value="0.0" />
  <param name="map_to_camera_init_roll" value="0.0" />
  <param name="map_to_camera_init_pitch" value="0.0" />
  <param name="map_to_camera_init_yaw" value="0.0" />

  <!-- Static Transform Publisher: map -> camera_init -->
  <node name="static_transform_publisher_map_to_camera" pkg="tf2_ros" type="static_transform_publisher"
        args="$(map_to_camera_init_x) $(map_to_camera_init_y) $(map_to_camera_init_z)
              $(map_to_camera_init_roll) $(map_to_camera_init_pitch) $(map_to_camera_init_yaw)
              map camera_init" />

  <!-- MPC Trajectory Tracking Node (First-Order Mass Point Model) -->
  <node name="traj_mpc_node" pkg="traj_mpc" type="traj_mpc_node" output="screen">
    <!-- MPC Basic Parameters -->
    <param name="horizon" value="10" />
    <param name="dt" value="0.1" />
    <param name="control_rate" value="10.0" />

    <!-- Per-axis Position Error Weights (P matrix diagonal) -->
    <!-- Higher values = more aggressive position tracking -->
    <param name="weight_pos_x" value="10.0" />
    <param name="weight_pos_y" value="10.0" />
    <param name="weight_pos_z" value="20.0" />

    <!-- Per-axis Velocity Weights (Q matrix diagonal) -->
    <!-- Lower values = allows faster movement; acts as damping -->
    <param name="weight_vel_x" value="1.0" />
    <param name="weight_vel_y" value="1.0" />
    <param name="weight_vel_z" value="0.5" />

    <!-- Per-axis Acceleration Weights (R matrix diagonal) -->
    <!-- Lower values = more aggressive acceleration allowed -->
    <param name="weight_acc_x" value="0.1" />
    <param name="weight_acc_y" value="0.1" />
    <param name="weight_acc_z" value="0.05" />

    <!-- Per-axis Velocity Constraints -->
    <param name="max_vel_x" value="2.0" />
    <param name="max_vel_y" value="2.0" />
    <param name="max_vel_z" value="2.0" />

    <!-- Per-axis Acceleration Constraints -->
    <!-- max_acc_z must be > gravity (9.81) for effective takeoff and altitude control -->
    <param name="max_acc_x" value="5.0" />
    <param name="max_acc_y" value="5.0" />
    <param name="max_acc_z" value="10.0" />

    <!-- Gravity Parameters -->
    <param name="gravity" value="9.81" />
    <!-- Set to true if the underlying velocity controller does NOT compensate for gravity -->
    <param name="need_gravity_compensation" value="false" />

    <!-- Topic Configuration Parameters -->
    <param name="odom_topic" value="/odom" />
    <param name="cmd_vel_topic" value="/cmd_vel" />
    <param name="path_topic" value="/path_exp" />
    <param name="position_exp_topic" value="/position_exp" />

    <!-- Trajectory File -->
    <param name="trajectory_file" value="$(find traj_mpc)/trajectories/example_trajectory.xml" />
  </node>
</launch>
